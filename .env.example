# ada-server config — copy to .env and fill in. Everything is optional; set what you use.
# The backend holds these keys; clients never see them.

# --- Provider keys (set at least one; the router picks a provider from the model id) ---
# Cloudflare Workers AI (models like @cf/meta/llama-3.3-70b-instruct):
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# Or route all providers through a Cloudflare AI Gateway URL:
# CLOUDFLARE_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/workers-ai/v1
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# (see src/server/config.ts for every supported provider + its key env)

# --- Server ---
# ADA_PORT=8787
# ADA_DATA_DIR=/data          # in Docker this is the mounted volume; leave as-is

# --- Enterprise / auth (optional) ---
# ADA_ADMIN_KEY=              # bootstrap admin (any long random string) → locks the backend
# ADA_OIDC_ISSUER=            # single-tenant OIDC issuer → SSO (see docs/enterprise-stage2-oidc.md)
# ADA_OIDC_CLIENT_ID=
# ADA_OIDC_ALLOWED_GROUPS=    # or ADA_OIDC_ALLOWED_DOMAINS=
