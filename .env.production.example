# ada-server — PUBLIC deployment config (container + Better Auth account sign-in).
# Copy to `.env` on the host (or paste these as the platform's env vars). NEVER commit the filled-in file.

# --- Provider key (the backend routes to real models; clients never see this) ---
# You use OpenRouter today. Set your real key here:
OPENROUTER_API_KEY=sk-or-REPLACE_ME
# (add ANTHROPIC_API_KEY / OPENAI_API_KEY / GROQ_API_KEY too if you want those providers)

# --- Better Auth: account sign-up / sign-in gates the backend ---
BETTER_AUTH_ENABLED=1
# A real 32-byte random secret (REQUIRED when auth is on). Keep it stable — rotating it invalidates all
# existing sessions. Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=REPLACE_WITH_A_RANDOM_32_BYTE_SECRET
# The PUBLIC https URL of this deployment (set to your platform URL after first deploy, then redeploy):
BETTER_AUTH_URL=https://REPLACE_WITH_YOUR_DEPLOY_URL
# Persist the accounts DB on the mounted volume — WITHOUT this it defaults to the container's
# ephemeral cwd and every restart wipes all accounts:
ADA_AUTH_DB=/data/ada-auth.db

# --- Server ---
ADA_PORT=8787
ADA_DATA_DIR=/data
